# Backend configuration (copy to .env; never commit real secrets).

# --- general ---
AIRPORT_ID=AUH
SESSION_TTL=1800
CORS_ORIGINS=*

# --- speech-to-text (TDD-01) ---
# false = stub STT (no model, API boots without a GPU). true = load Whisper.
LOAD_STT=false
WHISPER_MODEL=openai/whisper-small        # or your fine-tuned HF id / local path
WHISPER_LANGUAGE=arabic

# --- agent (TDD-02) ---
AGENT_BACKEND=stub                        # stub | langgraph (future)

# --- tts (TDD-05) ---
TTS_PROVIDER=stub                         # stub | elevenlabs | azure (future)
# TTS_API_KEY=
