# Backend configuration (copy to .env; never commit real secrets).

# --- general ---
AIRPORT_ID=AUH
SESSION_TTL=1800
CORS_ORIGINS=*

# --- speech-to-text (TDD-01) ---
# false = stub STT (no model, no GPU). true = load the fine-tuned Whisper (default).
LOAD_STT=true
WHISPER_MODEL=Amassu/whisper-small-darija  # DODa fine-tune (TDD-01); or a local ckpt path
WHISPER_LANGUAGE=arabic

# --- flight data (TDD-03) ---
# mock = canned flights (offline, no key). airlabs = real lookup by flight number.
FLIGHT_API_PROVIDER=mock
# AIRLABS_API_KEY=                         # required when FLIGHT_API_PROVIDER=airlabs (server-side only)
FLIGHT_CACHE_TTL=60                        # seconds; free tier is 1,000 req/month

# --- agent (TDD-02) ---
AGENT_BACKEND=langgraph                    # langgraph (default) | stub
LLM_PROVIDER=offline                       # offline (no key) | openai | groq
LLM_MODEL=gpt-4o-mini                      # used when LLM_PROVIDER=openai/groq
MAX_TOOL_HOPS=4                            # agent tool-call loop cap
# OPENAI_API_KEY=                          # required when LLM_PROVIDER=openai (server-side only)
# GROQ_API_KEY=                            # required when LLM_PROVIDER=groq (server-side only)

# --- knowledge base + RAG (TDD-04) ---
KB_RETRIEVER=chroma                       # chroma (real embeddings, local, no key) | keyword (dep-free)
KB_EMBEDDING_MODEL=intfloat/multilingual-e5-base   # multilingual (ar/ary/fr/en); runs on CPU
# KB_PERSIST_DIR=                         # defaults to backend/.kb_chroma; run `python -m app.kb.ingest --airport AUH`

# --- tts (TDD-05) ---
TTS_PROVIDER=local                        # local (MMS-TTS, on-CPU, no key) | stub (silent)
# TTS_MODEL_AR=facebook/mms-tts-ara       # per-language voice overrides (ary uses the ar voice)
# TTS_MODEL_FR=facebook/mms-tts-fra
# TTS_MODEL_EN=facebook/mms-tts-eng
